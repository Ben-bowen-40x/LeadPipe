{
  "profiles": {
    // *******************************************
    // Example
    // *******************************************
    "Example - All Options Dev": {
      "commandName": "Project",
      "commandLineArgs": "example -f ./ -s ../ -t ../../../",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Example - No Options": {
      "commandName": "Project",
      "commandLineArgs": "example",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

    // *******************************************
    // CatMan Update
    // *******************************************
    "Update CatMan Data: Refresh Data": {
      "commandName": "Project",
      "commandLineArgs": "catman -r",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Update CatMan Data: Get all Data": {
      "commandName": "Project",
      "commandLineArgs": "catman",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

    // *******************************************
    // Data Updating
    // *******************************************
    "Data update | Get all data": {
      "commandName": "Project",
      "commandLineArgs": "data -u",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    "Data update | Refresh data": {
      "commandName": "Project",
      "commandLineArgs": "data -Ru",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },

