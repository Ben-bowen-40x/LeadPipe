{
  "Ef": {
    "UseInMemoryDatabase": false,
    "SensitiveLogging": false,
    "LogLevel": "Warning"
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "SendGrid",
        "Args": {
          "apiKey": "",
          "fromEmail": "errors@yourdomain.com",
          "toEmail": "you@yourdomain.com",
          "restrictedToMinimumLevel": "Error",
          "batchPostingLimit": 5,
          "period": "00:05:00"
        }
      }
    ]
  }
}
